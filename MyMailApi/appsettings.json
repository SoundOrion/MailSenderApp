{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Mail": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UserName": "your@gmail.com",
    "Password": "your-app-password",
    "UseSsl": false,
    "DisplayName": "My Mail API",
    "TimeoutMilliseconds": 30000
  },
  "MailQueue": {
    "Capacity": 200,
    "MaxRetryCount": 3,
    "RetryDelaySeconds": 5
  },
  "MailDispatch": {
    "DefaultMode": "Direct"
  }
}
